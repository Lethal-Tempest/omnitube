<file path="frontend/index.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniTube AI - Chat with YouTube Videos</title>
  <!-- SEO Tags -->
  <meta name="description" content="Load any YouTube video transcript and chat with an AI assistant to get summaries, answers, and deep insights instantly.">
  
  <!-- Modern Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- CSS Stylesheet -->
  <link rel="stylesheet" href="index.css">
</head>
<body>
  <!-- Ambient background glow elements -->
  <div class="bg-glow blob-1"></div>
  <div class="bg-glow blob-2"></div>

  <div class="app-container">
    <!-- Header -->
    <header class="app-header">
      <div class="brand">
        <svg class="brand-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 3.88 12 3.88 12 3.88s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z" fill="#FF0000"/>
          <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#FFFFFF"/>
        </svg>
        <span class="brand-text">OmniTube <span class="accent-text">AI</span></span>
      </div>
      
      <!-- Built for Digital Heroes Link (Mandatory Requirement) -->
      <a href="https://digitalheroesco.com" target="_blank" rel="noopener noreferrer" class="hero-partner-btn" id="partnerBtn">
        Built for Digital Heroes
      </a>
    </header>

    <!-- MAIN VIEW 1: Video Loading Hero Screen -->
    <main class="main-content" id="setupView">
      <div class="hero-card">
        <h1 class="hero-title">Chat with any <span class="gradient-text">YouTube Video</span></h1>
        <p class="hero-subtitle">Enter a YouTube URL below to fetch the transcript, index it using vector embeddings, and start chatting with the content.</p>

        <form class="url-form" id="urlForm">
          <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            <input type="text" id="youtubeUrl" placeholder="Paste YouTube link (e.g. https://www.youtube.com/watch?v=...)" required autocomplete="off">
            <button type="submit" class="submit-btn" id="loadBtn">
              <span>Load Video</span>
              <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </div>
          <div class="error-msg" id="validationError"></div>
        </form>

        <div class="features-grid">
          <div class="feature-item">
            <div class="feature-icon-box">💡</div>
            <h3>Smart Summaries</h3>
            <p>Get instant summaries and core takeaways from any video transcript in seconds.</p>
          </div>
          <div class="feature-item">
            <div class="feature-icon-box">🧠</div>
            <h3>Vector-Search (RAG)</h3>
            <p>Queries map semantic concepts directly to sections of the transcript for precise context.</p>
          </div>
          <div class="feature-item">
            <div class="feature-icon-box">💬</div>
            <h3>Interactive Q&A</h3>
            <p>Ask clarifying questions, translate concepts, and quiz yourself on video materials.</p>
          </div>
        </div>
      </div>
    </main>

    <!-- LOADING VIEW: Video Indexing Screen -->
    <div class="loading-view hidden" id="loadingView">
      <div class="loading-card">
        <div class="spinner-container">
          <div class="pulse-ring"></div>
          <div class="spinner"></div>
        </div>
        <h2 id="loadingTitle">Fetching Transcript...</h2>
        <p id="loadingStatus">Connecting to YouTube APIs and downloading transcription tracks...</p>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </div>
    </div>

    <!-- MAIN VIEW 2: Chat Workspace (Split View) -->
    <main class="main-content workspace-view hidden" id="workspaceView">
      <!-- Left Panel: Video Info & Actions -->
      <aside class="sidebar">
        <div class="video-info-card">
          <div class="thumbnail-container">
            <img id="videoThumbnail" src="" alt="YouTube Video Thumbnail">
            <div class="thumbnail-overlay">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="23 7 16 12 23 17 23 7"></polygon>
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
              </svg>
            </div>
          </div>
          <h2 class="video-title" id="videoTitle">Loading Title...</h2>
          <p class="video-author" id="videoAuthor">YouTube Channel</p>
          
          <button class="change-video-btn" id="changeVideoBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Change Video
          </button>
        </div>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
          <div class="sidebar-partner-section">
            <a href="https://digitalheroesco.com" target="_blank" rel="noopener noreferrer" class="hero-partner-btn w-100" id="sidebarPartnerBtn">
              Built for Digital Heroes
            </a>
          </div>
          <!-- Developer Credit (Mandatory Requirement) -->
          <div class="dev-info">
            <p class="dev-label">Developer Contact</p>
            <p class="dev-name">Daksh</p>
            <p class="dev-email">dakshapjn@gmail.com</p>
          </div>
        </div>
      </aside>

      <!-- Right Panel: AI Chat Window -->
      <section class="chat-panel">
        <div class="chat-history" id="chatHistory">
          <!-- Messages will be injected here dynamically -->
        </div>

        <div class="chat-input-area">
          <form class="chat-form" id="chatForm">
            <textarea id="questionInput" placeholder="Ask a question about the transcript..." rows="1" required></textarea>
            <button type="submit" class="send-btn" id="sendBtn" title="Ask AI">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </form>
        </div>
      </section>
    </main>

    <!-- Footer for Landing View (Mandatory Requirement) -->
    <footer class="app-footer" id="mainFooter">
      <div class="footer-credit">
        <span class="credit-badge">Developer</span>
        <span class="credit-details">Daksh — <a href="mailto:dakshapjn@gmail.com">dakshapjn@gmail.com</a></span>
      </div>
      <div class="footer-copyright">
        © 2026 OmniTube AI. All rights reserved.
      </div>
    </footer>
  </div>

  <!-- JavaScript file -->
  <script src="app.js"></script>
</body>
</html>
</file>

<file path="frontend/manifest.json">
{
  "manifest_version": 3,
  "name": "YouTube Video AI",
  "version": "1.0.0",
