  border: 1px solid var(--border-light);
  border-radius: 16px;
  padding: 0.5rem;
  align-items: center;
  transition: var(--transition-normal);
  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
}

.input-wrapper:focus-within {
  border-color: var(--border-focus);
  box-shadow: var(--shadow-glow);
  background: rgba(10, 11, 16, 0.8);
}

.input-icon {
  width: 1.5rem;
  height: 1.5rem;
  color: var(--text-dark);
  margin-left: 1rem;
  margin-right: 0.75rem;
  flex-shrink: 0;
}

.input-wrapper input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-main);
  font-size: 1.05rem;
  outline: none;
  padding: 0.75rem 0.5rem;
  width: 100%;
}

.input-wrapper input::placeholder {
  color: var(--text-dark);
}

.submit-btn {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
  padding: 0.85rem 1.75rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: var(--transition-normal);
}

.submit-btn:hover {
  transform: translateY(-1px);
  filter: brightness(1.1);
  box-shadow: 0 8px 16px rgba(99, 102, 241, 0.25);
}

.submit-btn:active {
  transform: translateY(1px);
}

.arrow-icon {
  width: 1.2rem;
  height: 1.2rem;
  transition: var(--transition-fast);
}

.submit-btn:hover .arrow-icon {
  transform: translateX(3px);
}

.error-msg {
  color: var(--color-danger);
  font-size: 0.9rem;
  text-align: left;
  margin-top: 0.75rem;
  margin-left: 0.5rem;
  min-height: 1.25rem;
}

/* Features Grid */
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.feature-item {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--border-light);
  border-radius: 16px;
  padding: 1.5rem;
  text-align: left;
  transition: var(--transition-normal);
}

.feature-item:hover {
  background: rgba(255, 255, 255, 0.04);
  transform: translateY(-5px);
  border-color: rgba(255, 255, 255, 0.12);
}

.feature-icon-box {
  font-size: 1.75rem;
  margin-bottom: 1rem;
}

.feature-item h3 {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.feature-item p {
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.45;
}

/* Loading state view */
.loading-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-card {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-light);
  border-radius: 24px;
  padding: 4rem 3rem;
  max-width: 480px;
  width: 100%;
  text-align: center;
  box-shadow: var(--shadow-lg);
}

.spinner-container {
  position: relative;
  width: 80px;
  height: 80px;
  margin: 0 auto 2rem auto;
}

.spinner {
  width: 100%;
  height: 100%;
  border: 4px solid rgba(99, 102, 241, 0.1);
  border-left-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.pulse-ring {
  position: absolute;
  top: -10px;
  left: -10px;
  right: -10px;
  bottom: -10px;
  border-radius: 50%;
  border: 2px solid var(--color-secondary);
  opacity: 0;
  animation: pulse 2s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0% { transform: scale(0.9); opacity: 0; }
  50% { opacity: 0.3; }
  100% { transform: scale(1.1); opacity: 0; }
}

.loading-card h2 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  margin-bottom: 0.75rem;
}

.loading-card p {
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.5;
  margin-bottom: 2rem;
}

.progress-bar {
  background: rgba(255, 255, 255, 0.05);
  height: 6px;
  border-radius: 99px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  width: 15%;
  background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  border-radius: 99px;
  animation: simulateProgress 8s ease-out forwards;
}

@keyframes simulateProgress {
  0% { width: 5%; }
  20% { width: 35%; }
  50% { width: 60%; }
  80% { width: 85%; }
  100% { width: 95%; }
}

/* Workspace layout (Loaded state) */
.workspace-view {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 2rem;
  padding: 1.5rem 0;
  height: calc(100vh - 120px);
  align-items: stretch;
}

/* Sidebar */
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  height: 100%;
}

.video-info-card {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-light);
  border-radius: 20px;
  padding: 1.5rem;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.thumbnail-container {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 1.25rem;
  box-shadow: var(--shadow-md);
}

.thumbnail-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.thumbnail-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: var(--transition-fast);
}

.thumbnail-container:hover .thumbnail-overlay {
  opacity: 1;
}

.thumbnail-overlay svg {
  width: 2.5rem;
  height: 2.5rem;
  color: #fff;
}

.video-title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  line-height: 1.35;
  margin-bottom: 0.5rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.video-author {
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-bottom: 1.5rem;
}

.change-video-btn {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main);
  border: 1px solid var(--border-light);
  border-radius: 10px;
  padding: 0.75rem 1.25rem;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: var(--transition-fast);
  width: 100%;
  justify-content: center;
}

.change-video-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.sidebar-footer {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.sidebar-partner-section {
  width: 100%;
}

.sidebar-partner-section .hero-partner-btn {
  width: 100%;
  padding: 0.75rem 1rem;
}

.dev-info {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--border-light);
  border-radius: 12px;
  padding: 1rem;
}

.dev-label {
  color: var(--text-dark);
  font-size: 0.75rem;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 0.5px;
  margin-bottom: 0.25rem;
}

.dev-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--text-main);
}

.dev-email {
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* Chat Panel */
.chat-panel {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-light);
  border-radius: 20px;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

.chat-history {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

/* Custom Scrollbar for Chat */
.chat-history::-webkit-scrollbar {
  width: 6px;
}

.chat-history::-webkit-scrollbar-track {
  background: transparent;
}

.chat-history::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 99px;
}

.chat-history::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.2);
}

/* Message Bubbles */
.message {
  display: flex;
  flex-direction: column;
  max-width: 85%;
  animation: messageFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes messageFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.message.user {
  align-self: flex-end;
}

.message.assistant {
  align-self: flex-start;
}

.message-meta {
  font-size: 0.75rem;
  color: var(--text-dark);
  font-weight: 600;
  margin-bottom: 0.25rem;
  margin-left: 0.5rem;
}

.message.user .message-meta {
  margin-left: 0;
  margin-right: 0.5rem;
  text-align: right;
}

.message-bubble {
  padding: 1rem 1.25rem;
  border-radius: 16px;
  font-size: 0.95rem;
  line-height: 1.5;
  word-break: break-word;
}

.message.user .message-bubble {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
  color: #fff;
  border-bottom-right-radius: 4px;
  box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
}

.message.assistant .message-bubble {
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-main);
  border: 1px solid var(--border-light);
  border-bottom-left-radius: 4px;
}

/* Markdown response rendering */
.message-bubble p {
  margin-bottom: 0.5rem;
}

.message-bubble p:last-child {
  margin-bottom: 0;
}

.message-bubble ul, .message-bubble ol {
  margin-left: 1.25rem;
  margin-bottom: 0.5rem;
}

/* Chat Input Bar */
.chat-input-area {
  padding: 1.25rem 1.5rem;
  border-top: 1px solid var(--border-light);
  background: rgba(10, 11, 16, 0.3);
}

.chat-form {
  display: flex;
  background: rgba(8, 9, 13, 0.7);
  border: 1px solid var(--border-light);
  border-radius: 12px;
  padding: 0.5rem;
  align-items: center;
  transition: var(--transition-normal);
}

.chat-form:focus-within {
  border-color: var(--border-focus);
  box-shadow: var(--shadow-glow);
}

.chat-form textarea {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-main);
  font-family: var(--font-sans);
  font-size: 0.95rem;
  outline: none;
  padding: 0.5rem;
  resize: none;
  max-height: 120px;
  min-height: 24px;
  line-height: 1.4;
}

.chat-form textarea::placeholder {
  color: var(--text-dark);
}

.send-btn {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: 8px;
  width: 2.25rem;
  height: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: var(--transition-fast);
  flex-shrink: 0;
}

.send-btn:hover {
  background: var(--color-primary-hover);
  transform: scale(1.05);
}

.send-btn:active {
  transform: scale(0.95);
}

.send-btn svg {
  width: 1.1rem;
  height: 1.1rem;
}

/* AI Typing Loading Indicator */
.typing-indicator {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 0.5rem 0.25rem;
}

.typing-dot {
  width: 6px;
  height: 6px;
  background-color: var(--text-muted);
  border-radius: 50%;
  animation: typingBounce 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typingBounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* Footer credit styling */
.app-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 2rem 0;
  border-top: 1px solid var(--border-light);
  margin-top: auto;
  font-size: 0.85rem;
  color: var(--text-dark);
}

.footer-credit {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.credit-badge {
  background: rgba(99, 102, 241, 0.1);
  color: var(--color-primary);
  border: 1px solid rgba(99, 102, 241, 0.2);
  padding: 0.15rem 0.4rem;
  border-radius: 4px;
  font-weight: 700;
  font-size: 0.75rem;
  text-transform: uppercase;
}

.credit-details a {
  color: var(--text-muted);
  text-decoration: none;
  transition: var(--transition-fast);
}

.credit-details a:hover {
  color: var(--color-primary);
  text-decoration: underline;
}

/* Responsive Breakpoints */
@media (max-width: 992px) {
  .workspace-view {
    grid-template-columns: 1fr;
    height: auto;
    max-height: none;
  }
  
  .sidebar {
    height: auto;
  }
  
  .chat-panel {
    height: 500px;
  }
}

@media (max-width: 768px) {
  .app-container {
    padding: 0 1rem;
  }
  
  .hero-card {
    padding: 2.5rem 1.5rem;
  }
  
  .hero-title {
    font-size: 2.25rem;
  }
  
  .features-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  
  .app-footer {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    padding: 1.5rem 0;
  }
}
